# Copy this file to .env and fill in real values for local development.

# PostgreSQL connection string. Matches docker-compose.yml defaults.
DATABASE_URL="postgresql://ontime:ontime@localhost:5432/ontime?schema=public"

# Used to sign session cookies (jose/HS256). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="replace-with-a-long-random-string"

# Base URL of the app, used to build absolute links in emails
# (verification, password reset). No trailing slash.
APP_URL="http://localhost:3000"

# SMTP settings for sending real email. If SMTP_HOST is unset, the app
# falls back to logging emails to the console instead of sending them,
# which is fine for local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="On-Time <no-reply@ontime.am>"
