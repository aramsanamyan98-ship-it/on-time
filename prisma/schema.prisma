// Prisma schema for On-Time (see docs/05_Database.md)
//
// Build stage: auth (specialists + token tables), plus the Phase 2
// specialist-profile tables (services, working_hours) per
// docs/08_Roadmap.md. Appointments, blocked_time, portfolio_photos,
// notifications_log, and referrals are still out of scope until their
// respective phases.
//
// Deviations from the literal field list in 05_Database.md, and why:
// - `display_name` and `slug` are populated automatically at registration
//   (slug from a slugified/uniquified display_name, display_name from the
//   email's local part) rather than collected in a form. Both remain
//   editable once profile UI exists — the doc already calls the slug
//   "auto-generated from name, editable once", so this just applies the
//   same pattern to display_name. Editing either is still not built (not
//   required by 08_Roadmap.md Phase 2's field list).
// - `working_hours.start_time`/`end_time` are stored as "HH:mm" strings
//   rather than a DB `time` column: v1 only needs them for display and
//   slot-generation math done in application code (Phase 4), and a plain
//   string avoids Prisma's `@db.Time` values round-tripping as full `Date`
//   objects for what is really just a wall-clock time.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  am
  ru
  en
}

enum Plan {
  basic
  starter
  pro
}

model Specialist {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  displayName        String    @map("display_name")
  slug               String    @unique
  profilePhotoUrl    String?   @map("profile_photo_url")
  coverPhotoUrl      String?   @map("cover_photo_url")
  bio                String?
  phone              String?
  address            String?
  timezone           String    @default("Asia/Yerevan")
  instagramUrl       String?   @map("instagram_url")
  languagePreference Language  @default(am) @map("language_preference")
  plan               Plan      @default(basic)
  trialEndsAt        DateTime? @map("trial_ends_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  services                Service[]
  workingHours            WorkingHours[]

  @@map("specialists")
}

model Service {
  id               String     @id @default(uuid())
  specialistId     String     @map("specialist_id")
  specialist       Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  name             String
  durationMinutes  Int        @map("duration_minutes")
  priceAmd         Int        @map("price_amd")
  description      String?
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@index([specialistId])
  @@map("services")
}

// dayOfWeek follows JS Date#getDay() convention: 0 = Sunday ... 6 = Saturday.
// Exactly one row per specialist per day of week (upserted as a set from
// the working-hours settings form) — see docs/05_Database.md.
model WorkingHours {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        @map("day_of_week")
  startTime    String?    @map("start_time") // "HH:mm", null when isDayOff
  endTime      String?    @map("end_time") // "HH:mm", null when isDayOff
  isDayOff     Boolean    @default(false) @map("is_day_off")

  @@unique([specialistId, dayOfWeek])
  @@map("working_hours")
}

model EmailVerificationToken {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("password_reset_tokens")
}
