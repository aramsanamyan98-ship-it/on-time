// Prisma schema for On-Time (see docs/05_Database.md)
//
// Build stage: auth (specialists + token tables), Phase 2 specialist-profile
// tables (services, working_hours), Phase 3 portfolio_photos, and Phase 4
// booking-engine tables (appointments, blocked_time) per docs/08_Roadmap.md.
// notifications_log and referrals are still out of scope until Phase 6/7.
//
// Deviations from the literal field list in 05_Database.md, and why:
// - `display_name` and `slug` are populated automatically at registration
//   (slug from a slugified/uniquified display_name, display_name from the
//   email's local part) rather than collected in a form. Both remain
//   editable once profile UI exists — the doc already calls the slug
//   "auto-generated from name, editable once", so this just applies the
//   same pattern to display_name. Editing either is still not built (not
//   required by 08_Roadmap.md Phase 2's field list).
// - `working_hours.start_time`/`end_time` are stored as "HH:mm" strings
//   rather than a DB `time` column: v1 only needs them for display and
//   slot-generation math done in application code (Phase 4), and a plain
//   string avoids Prisma's `@db.Time` values round-tripping as full `Date`
//   objects for what is really just a wall-clock time.
// - `appointments.booking_token` is stored as the raw random token (not a
//   hash like the auth token tables). Unlike a password-reset/verification
//   token, this is a long-lived capability link a guest may reopen many
//   times (view, then later cancel/reschedule) rather than a one-time
//   secret exchanged once, 05_Database.md names the column `booking_token`
//   (not `_hash`) exactly for this reason, and 32 bytes of CSPRNG output is
//   already unguessable without needing the extra hash-on-lookup layer.
// - The no-double-booking rule (05_Database.md) is enforced with a
//   Postgres EXCLUDE constraint (`btree_gist`, gist index on
//   specialist_id + tstzrange(start_at, end_at), partial WHERE status <>
//   'cancelled') rather than a plain unique constraint, since bookings
//   aren't on a fixed slot grid — any two overlapping ranges must be
//   rejected, not just exact duplicate start times. Prisma's schema DSL
//   can't express EXCLUDE constraints, so it's added by hand-editing the
//   generated migration SQL (see prisma/migrations).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Language {
  am
  ru
  en
}

enum Plan {
  basic
  starter
  pro
}

enum AppointmentStatus {
  confirmed
  cancelled
  completed
  no_show
}

enum AppointmentSource {
  guest_booking
  manual_specialist_entry
}

model Specialist {
  id                 String    @id @default(uuid())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  displayName        String    @map("display_name")
  slug               String    @unique
  profilePhotoUrl    String?   @map("profile_photo_url")
  coverPhotoUrl      String?   @map("cover_photo_url")
  bio                String?
  phone              String?
  address            String?
  timezone           String    @default("Asia/Yerevan")
  instagramUrl       String?   @map("instagram_url")
  languagePreference Language  @default(am) @map("language_preference")
  plan               Plan      @default(basic)
  trialEndsAt        DateTime? @map("trial_ends_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")

  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  services                Service[]
  workingHours            WorkingHours[]
  portfolioPhotos         PortfolioPhoto[]
  appointments            Appointment[]
  blockedTime             BlockedTime[]

  @@map("specialists")
}

model Service {
  id               String     @id @default(uuid())
  specialistId     String     @map("specialist_id")
  specialist       Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  name             String
  durationMinutes  Int        @map("duration_minutes")
  priceAmd         Int        @map("price_amd")
  description      String?
  isActive         Boolean    @default(true) @map("is_active")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  appointments Appointment[]

  @@index([specialistId])
  @@map("services")
}

// dayOfWeek follows JS Date#getDay() convention: 0 = Sunday ... 6 = Saturday.
// Exactly one row per specialist per day of week (upserted as a set from
// the working-hours settings form) — see docs/05_Database.md.
model WorkingHours {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  dayOfWeek    Int        @map("day_of_week")
  startTime    String?    @map("start_time") // "HH:mm", null when isDayOff
  endTime      String?    @map("end_time") // "HH:mm", null when isDayOff
  isDayOff     Boolean    @default(false) @map("is_day_off")

  @@unique([specialistId, dayOfWeek])
  @@map("working_hours")
}

model PortfolioPhoto {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  imageUrl     String     @map("image_url")
  sortOrder    Int        @map("sort_order")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("portfolio_photos")
}

// Specialist-private unavailable time (lunch, personal errands, etc.) that
// blocks slot generation the same way an appointment does, without being
// one (07_Business_Rules.md / 05_Database.md). No management UI ships in
// Phase 4 — see 08_Roadmap.md Phase 4 scope — but the availability engine
// already reads this table so it's ready for that UI later.
model BlockedTime {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  startAt      DateTime   @map("start_at")
  endAt        DateTime   @map("end_at")
  reason       String?
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("blocked_time")
}

// See 05_Database.md `appointments` and 07_Business_Rules.md Booking Rules.
// The no-overlap guarantee is a Postgres EXCLUDE constraint added by hand
// to the generated migration (Prisma can't express it) — see the schema
// header comment above.
model Appointment {
  id           String            @id @default(uuid())
  specialistId String            @map("specialist_id")
  specialist   Specialist        @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  serviceId    String            @map("service_id")
  // Services are only ever deactivated, never deleted, from the app
  // (07_Business_Rules.md: "past appointments ... must remain intact") —
  // Restrict makes that invariant explicit at the DB level too.
  service      Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  startAt      DateTime          @map("start_at")
  endAt        DateTime          @map("end_at")
  status       AppointmentStatus @default(confirmed)
  guestName    String            @map("guest_name")
  guestPhone   String            @map("guest_phone")
  guestEmail   String?           @map("guest_email")
  guestNotes   String?           @map("guest_notes")
  source       AppointmentSource @default(guest_booking)
  bookingToken String            @unique @map("booking_token")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([specialistId])
  @@index([serviceId])
  @@map("appointments")
}

model EmailVerificationToken {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id           String     @id @default(uuid())
  specialistId String     @map("specialist_id")
  specialist   Specialist @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  tokenHash    String     @unique @map("token_hash")
  expiresAt    DateTime   @map("expires_at")
  consumedAt   DateTime?  @map("consumed_at")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@index([specialistId])
  @@map("password_reset_tokens")
}
